                <span class="font-medium">B. 冰箱內部隔層</span>
              </div>
              <div class="quiz-option p-4 rounded-xl border-2 border-border hover:border-accent" data-correct="false">
                <span class="font-medium">C. 冷凍庫</span>
              </div>
            </div>
            <p class="text-xs text-muted mt-3 opacity-0 transition-opacity duration-300" id="explanation-2">提示：冰箱門溫度變化大，容易造成雞蛋變質。</p>
          </div>

          <!-- Result -->
          <div class="quiz-step hidden text-center py-8" data-step="result">
            <div class="w-20 h-20 bg-accent-light rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-fg mb-2">太棒了！你是食物管理達人</h3>
            <p class="text-muted mb-6">恭喜你完成測驗，看來你的冰箱一定很乾淨！</p>
            <a href="index.html#form" class="btn-primary inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-xl font-medium">
              立即開始管理
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Report Form Section -->
  <section id="report" class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12 reveal">
        <span class="inline-block text-accent font-medium text-sm tracking-wider uppercase mb-4">意見回饋</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-fg mb-4">問題通報與建議</h2>
        <p class="text-muted">發現系統問題或有新功能建議？請填寫下方表單通知我們。</p>
      </div>

      <form id="reportForm" class="reveal reveal-delay-1 bg-card rounded-3xl border border-border shadow-sm p-6 sm:p-10">
        <div class="space-y-6">
          <div>
            <label for="reportType" class="block text-sm font-medium text-fg mb-2">問題類型</label>
            <select id="reportType" name="reportType" class="w-full px-4 py-3 rounded-xl border border-border bg-white focus:outline-none focus:border-accent transition-colors">
              <option value="bug">系統錯誤</option>
              <option value="suggestion">功能建議</option>
              <option value="data">資料問題</option>
              <option value="other">其他</option>
            </select>
          </div>

          <div>
            <label for="reportName" class="block text-sm font-medium text-fg mb-2">聯絡姓名</label>
            <input type="text" id="reportName" name="reportName" placeholder="您的稱呼" class="w-full px-4 py-3 rounded-xl border border-border bg-white focus:outline-none focus:border-accent transition-colors">
          </div>

          <div>
            <label for="reportDesc" class="block text-sm font-medium text-fg mb-2">問題描述 <span class="text-red-400">*</span></label>
            <textarea id="reportDesc" name="reportDesc" rows="4" required placeholder="請詳細描述您遇到的問題或建議內容..." class="w-full px-4 py-3 rounded-xl border border-border bg-white focus:outline-none focus:border-accent transition-colors resize-none"></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium text-fg mb-2">上傳截圖（選填）</label>
            <div class="border-2 border-dashed border-border rounded-xl p-6 text-center hover:border-accent transition-colors cursor-pointer">
              <svg class="w-8 h-8 mx-auto text-muted mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <p class="text-sm text-muted">點擊或拖曳檔案至此處</p>
              <p class="text-xs text-muted mt-1">支援 JPG, PNG 格式</p>
            </div>
          </div>
        </div>

        <button type="submit" class="btn-primary w-full bg-accent text-white px-8 py-4 rounded-xl font-medium text-lg hover:bg-accent-dark mt-8 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          送出表單
        </button>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-12 px-4 sm:px-6 lg:px-8 border-t border-border bg-subtle/50">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-accent rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <span class="font-bold text-fg">食品日期管理</span>
        </div>
        <nav class="flex items-center gap-6 text-sm text-muted">
          <a href="index.html" class="hover:text-fg transition-colors">回首頁</a>
          <a href="#features-detail" class="hover:text-fg transition-colors">功能詳情</a>
          <a href="#report" class="hover:text-fg transition-colors">問題通報</a>
        </nav>
        <p class="text-sm text-muted">Made with care by Vincy & Charisa</p>
      </div>
    </div>
  </footer>

  <!-- Success Modal -->
  <div id="successModal" class="modal fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
    <div class="modal-content bg-card rounded-3xl p-8 sm:p-12 max-w-md w-full text-center relative overflow-hidden">
      <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h3 class="text-2xl font-bold text-fg mb-2">已成功送出</h3>
      <p class="text-muted mb-6">感謝您的回報，我們會盡快處理！</p>
      <button id="closeModalBtn" class="w-full px-6 py-3 rounded-xl bg-accent text-white font-medium hover:bg-accent-dark transition-colors">關閉</button>
    </div>
  </div>

  <script>
    // Initialize Variables
    const menuBtn = document.getElementById('menuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const reportForm = document.getElementById('reportForm');
    const successModal = document.getElementById('successModal');
    const closeModalBtn = document.getElementById('closeModalBtn');
    
    let isMenuOpen = false;

    // Mobile Menu
    menuBtn.addEventListener('click', () => {
      isMenuOpen = !isMenuOpen;
      mobileMenu.classList.toggle('open', isMenuOpen);
    });

    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => { isMenuOpen = false; mobileMenu.classList.remove('open'); });
    });

    // Scroll Reveal
    function initScrollReveal() {
      const revealElements = document.querySelectorAll('.reveal');
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      
      if (prefersReducedMotion) { revealElements.forEach(el => el.classList.add('visible')); return; }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('visible'); });
      }, { rootMargin: '0px 0px -80px 0px', threshold: 0.1 });

      revealElements.forEach(el => observer.observe(el));
    }

    // Tabs Logic
    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;

        tabButtons.forEach(b => {
          b.classList.remove('active');
          b.classList.add('text-muted');
        });
        btn.classList.add('active');
        btn.classList.remove('text-muted');

        tabContents.forEach(content => {
          content.classList.remove('active');
          if (content.id === target) content.classList.add('active');
        });
      });
    });

    // Quiz Logic
    const quizSteps = document.querySelectorAll('.quiz-step');
    const quizContainer = document.getElementById('quiz-container');
    let currentStep = 0;

    function handleQuizSelection(e) {
      const option = e.target.closest('.quiz-option');
      if (!option) return;

      const isCorrect = option.dataset.correct === 'true';
      const parentStep = option.closest('.quiz-step');
      const options = parentStep.querySelectorAll('.quiz-option');

      // Disable further clicks
      options.forEach(opt => {
        opt.style.pointerEvents = 'none';
        if (opt.dataset.correct === 'true') {
          opt.classList.add('correct');
        } else if (opt === option && !isCorrect) {
          opt.classList.add('incorrect');
        }
      });

      // Show explanation if exists
      const explanation = parentStep.querySelector('[id^="explanation"]');
      if (explanation) explanation.classList.replace('opacity-0', 'opacity-100');

      // Next step
      setTimeout(() => {
        parentStep.classList.add('hidden');
        currentStep++;
        if (currentStep < quizSteps.length) {
          quizSteps[currentStep].classList.remove('hidden');
        }
      }, 1500);
    }

    quizContainer.addEventListener('click', handleQuizSelection);

    // Form Submission
    reportForm.addEventListener('submit', (e) => {
      e.preventDefault();
      successModal.classList.add('show');
      reportForm.reset();
    });

    closeModalBtn.addEventListener('click', () => {
      successModal.classList.remove('show');
    });
    
    successModal.addEventListener('click', (e) => {
        if (e.target === successModal) successModal.classList.remove('show');
    });

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      initScrollReveal();
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768 && isMenuOpen) { isMenuOpen = false; mobileMenu.classList.remove('open'); }
    });
  </script>
</body>
</html>
